{
  "version": 2,
  "builds": [
    { "src": "api/webhook.py", "use": "@vercel/python" },
    { "src": "api/payment_webhook.py", "use": "@vercel/python" },
    { "src": "api/worker.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/webhook", "dest": "api/webhook.py" },
    { "src": "/api/payment", "dest": "api/payment_webhook.py" },
    { "src": "/api/worker", "dest": "api/worker.py" }
  ],
  "crons": [
    {
      "path": "/api/worker",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "api/webhook.py": {
      "maxDuration": 30
    },
    "api/payment_webhook.py": {
      "maxDuration": 15
    },
    "api/worker.py": {
      "maxDuration": 60
    }
  }
}
